diff --git a/mattergen/common/data/transform.py b/mattergen/common/data/transform.py
index 7657317..8564f73 100644
--- a/mattergen/common/data/transform.py
+++ b/mattergen/common/data/transform.py
@@ -41,6 +41,22 @@ def set_chemical_system_string(sample: ChemGraph) -> ChemGraph:
     )
 
 
+def set_composition_count(sample: ChemGraph) -> ChemGraph:
+    """Per-element atom COUNT vector, shape (1, MAX_ATOMIC_NUM+1).
+
+    Sibling of set_chemical_system but preserves the count instead of
+    binarizing to presence: count[Z] = number of atoms of element Z in this
+    structure (index 0 unused). This distinguishes Ni4P4 from Ni2P2, giving a
+    Mechanism-2 cond_field the same exact-multiset information that CSP node
+    features carry for free. Derived on-the-fly from atomic_numbers (no
+    sidecar), exactly like set_chemical_system_string.
+    """
+    counts = torch.eye(MAX_ATOMIC_NUM + 1, device=sample.atomic_numbers.device)[
+        sample.atomic_numbers
+    ].sum(0)[None]
+    return sample.replace(composition_count=counts)
+
