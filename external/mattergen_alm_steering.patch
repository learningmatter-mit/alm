index ecd0f39..aa99dc5 100644
--- a/mattergen/diffusion/sampling/classifier_free_guidance.py
+++ b/mattergen/diffusion/sampling/classifier_free_guidance.py
@@ -98,3 +98,69 @@ class GuidedPredictorCorrector(PredictorCorrector):
                     for k in self._multi_corruption.corrupted_fields
