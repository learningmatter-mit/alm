+class MultiBranchGuidedPredictorCorrector(GuidedPredictorCorrector):
+    """Composition-preserving two-scale classifier-free guidance (mclm #118).
+
+    Combines three score evaluations under different conditioning states::
+
+        s = s_null + g_comp * (s_comp - s_null) + g_text * (s_full - s_comp)
+
+    where
+        s_null : all conditioning dropped          (to_null_fn)
+        s_comp : composition kept, text dropped     (to_comp_fn)
+        s_full : all conditioning kept              (to_full_fn)
+
+    Keeping composition pinned in the negative branch lets ``g_text`` amplify the
+    *semantic* (text) residual without fighting composition -- unlike the
+    single-branch ``GuidedPredictorCorrector`` whose negative branch is fully
+    unconditional. Requires a model trained with iid per-field dropout so all
+    three conditioning states are in-distribution, and (ideally) a learned null
+    rather than ``ZerosEmbedding`` for the text field.
+
+    Computed as three *separate* score-model forwards rather than one batched
+    forward: the branches differ only in per-field ``_USE_UNCONDITIONAL_EMBEDDING``
+    state (same structures), so the per-field combination is aligned by
+    construction, and we avoid the collate-then-PyG-index split the single-branch
+    path relies on. Costs ~3x the score evaluations -- acceptable at sampling time.
+    """
+
+    def __init__(
+        self,
+        *,
+        guidance_scale_comp: float,
+        guidance_scale_text: float,
+        to_null_fn: BatchTransform,
+        to_comp_fn: BatchTransform,
+        to_full_fn: BatchTransform | None = None,
+        **kwargs,
+    ):
+        # GuidedPredictorCorrector requires guidance_scale + remove/keep fns; we
+        # override _score_fn, so these are only stand-ins for the base machinery.
+        super().__init__(
+            guidance_scale=1.0,
+            remove_conditioning_fn=to_null_fn,
+            keep_conditioning_fn=to_full_fn,
+            **kwargs,
+        )
+        self._guidance_scale_comp = guidance_scale_comp
+        self._guidance_scale_text = guidance_scale_text
+        self._to_null_fn = to_null_fn
+        self._to_comp_fn = to_comp_fn
+        self._to_full_fn = to_full_fn or identity
+
+    def _score_fn(self, x: Diffusable, t: torch.Tensor) -> Diffusable:
+        # raw (unguided) score model, bypassing GuidedPredictorCorrector._score_fn
+        base = super(GuidedPredictorCorrector, self)
+        s_null = base._score_fn(x=self._to_null_fn(x), t=t)
+        s_comp = base._score_fn(x=self._to_comp_fn(x), t=t)
+        s_full = base._score_fn(x=self._to_full_fn(x), t=t)
+        return s_full.replace(
+            **{
+                k: s_null[k]
+                + self._guidance_scale_comp * (s_comp[k] - s_null[k])
+                + self._guidance_scale_text * (s_full[k] - s_comp[k])
+                for k in self._multi_corruption.corrupted_fields
+            }
+        )
