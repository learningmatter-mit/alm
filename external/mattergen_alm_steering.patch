+# mclm Stage 3a — ALM-derived conditioning channel.
+#
+# At training time, ChemGraph["alm_embedding"] is a (K * llm_hidden_dim,) = (32768,)
+# float32 vector per structure: the K=8 Qwen3-8B final-layer hidden states at the
+# [atoms_{i}] output token positions for the corresponding text prompt, concatenated.
+# AtomsMapper reshapes the flat input to (B, K, hidden_dim), projects each of the K
+# positions independently to (B, K, out_dim), then mean-pools across K → (B, 512).
+# That 512-d vector flows through the adapter's cond_adapt path into GemNetTCtrl.
+# Gradient from L_diff flows back through AtomsMapper into Stage 2 LoRA via Qwen3.
+# AtomsMapper params: ~9M (LLaVA-projector size; was 136M in the prior concat MLP).
+#
+# unconditional_embedding_module is rewritten to ZerosEmbedding by GemNetTAdapter.__init__
+# at adapter.py:43-46 — the choice here is moot but EmbeddingVector matches the
+# pattern of all the existing property_embeddings YAMLs.
+_target_: mattergen.property_embeddings.PropertyEmbedding
+name: alm_embedding
+unconditional_embedding_module:
+  _target_: mattergen.property_embeddings.EmbeddingVector
+  hidden_dim: ${lightning_module.diffusion_module.model.hidden_dim}
+# NOTE: imports atoms_mapper as a bare module name. The mclm `alm/` directory must
+# be on PYTHONPATH when running `mattergen-finetune`/`mattergen-generate` (and at
+# Lightning-checkpoint resume/load), e.g.
+#   PYTHONPATH=<repo>/src/alm:$PYTHONPATH mattergen-finetune ...
+# `alm/` is not a Python package today (alm/__init__.py would collide with alm/alm.py),
+# so a dotted import path won't resolve. PYTHONPATH is the workable option.
+conditional_embedding_module:
+  _target_: bridge.AtomsMapper
+  hidden_dim: 4096   # Qwen3-8B hidden dim; input shape (B, K*hidden_dim) flattens to (B, K, hidden_dim)
+  mid_dim: 2048      # bottleneck inside the per-position MLP
+  out_dim: ${lightning_module.diffusion_module.model.hidden_dim}
+  K: 8
+scaler:
+  _target_: torch.nn.Identity
